# PostgreSQL connection (matches docker-compose.yml defaults)
# --- Local dev (optional) ---
# Leave DATABASE_URL blank to build it from the POSTGRES_* parts below (defaults already
# point at the dev container on localhost:5433). Set it only to override entirely.
# DATABASE_URL=postgresql://diaspora:diaspora@localhost:5433/diaspora

# --- Production stack (docker-compose.prod.yml) ---
# Strong DB password — ANY characters are now safe (the URL is encoded in code).
POSTGRES_PASSWORD=change-me-to-a-strong-password
# Your domain pointed at the VPS IP, for free HTTPS via the optional `tls` profile.
DOMAIN=yourdomain.com

# Pipeline behaviour
# Auto-apply new inserts whose confidence_score >= this threshold (skip approval queue).
AUTO_APPROVE_MIN_CONFIDENCE=0.6
# If false, every insert/update is routed to the human approval queue.
AUTO_APPROVE_LOW_RISK=true

# Scraper politeness
# Events: public iCalendar (.ics) feed URLs the event agent ingests (comma-separated).
# e.g. temple/community-org calendar export URLs. High-confidence events auto-approve;
# the rest appear under Admin → Events for approval.
EVENT_ICAL_FEEDS=

OVERPASS_URL=https://overpass-api.de/api/interpreter
SCRAPER_USER_AGENT=indo-usa-diaspora-mcp/0.1 (contact: manvigallc007@gmail.com)
SCRAPER_TIMEOUT_SECONDS=180

# Embeddings (semantic search)
# hashing = zero-dependency default; sentence_transformers = real semantics (pip install
# sentence-transformers, pulls torch); none = disable (search falls back to trigram).
# hashing = zero-dep default. fastembed = real semantic search (recommended; needs the
# `semantic` extra: pip install -e ".[semantic]", downloads a ~130MB model on first use).
EMBEDDING_PROVIDER=hashing
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Outreach & claiming
PLATFORM_NAME=Indian Eats Directory
CLAIM_BASE_URL=https://yourdomain.com/claim

# Public base URL of the claim/web app (used for Stripe redirect URLs)
PUBLIC_WEB_URL=http://YOUR_VPS_IP:8080

# Admin dashboard + owner portal. Blank ADMIN_PASSWORD disables /admin.
# SECRET_KEY signs session cookies + magic-link login tokens — set a long random value.
ADMIN_PASSWORD=
SECRET_KEY=change-me-to-a-long-random-string
REPORT_EMAIL=

# Payments (Stripe) — OPTIONAL. Blank STRIPE_SECRET_KEY = manual featuring (no checkout).
# Stripe charges only per sale (~2.9% + 30c), no monthly fee.
#   STRIPE_SECRET_KEY=sk_live_xxx   (from dashboard.stripe.com/apikeys)
#   STRIPE_WEBHOOK_SECRET=whsec_xxx (from the webhook you create -> /stripe/webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CENTS=3000
STRIPE_CURRENCY=usd
FEATURED_DAYS=30
# Selling Featured placement stays OFF until a city+vertical has provable traffic (don't sell
# placement against zero audience). Stripe plumbing stays wired; flip to true to enable.
FEATURED_SALES_ENABLED=false
OUTREACH_CONTACT_EMAIL=manvigallc007@gmail.com
OUTREACH_COOLDOWN_DAYS=21
# CAN-SPAM: a valid physical postal address is REQUIRED in every commercial email.
# Outreach auto-send stays OFF until this is set (until then it only drafts messages).
# A registered-agent / business mailing address or PO box is fine.
OUTREACH_POSTAL_ADDRESS=
# Slow ramp: max emails auto-sent per day across the whole platform (keep low to protect
# sender reputation and stay out of spam folders; raise gradually).
OUTREACH_DAILY_SEND_CAP=15

# Email delivery (OPTIONAL, zero-cost). Leave SMTP_HOST blank = outreach stays draft-only.
# NOTE: even with SMTP set, nothing sends until OUTREACH_POSTAL_ADDRESS is also set.
# For deliverability, send from your OWN domain with SPF/DKIM/DMARC configured — bulk cold
# email from a plain @gmail.com address will land in spam and risks account suspension.
# Free option: Gmail SMTP with an App Password (Google account → Security → App passwords).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=youraddress@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Human chatbot front-end (/chat). Default = free, no-LLM semantic-search replies ($0).
# To turn on a real conversational LLM, set LLM_PROVIDER to a preset and add LLM_API_KEY.
# The preset fills the base URL + a sensible model + tool-calling mode for you.
#
#   groq    -> FREE tier, ~1s, no credit card. RECOMMENDED for a snappy free chatbot.
#              Get a key at https://console.groq.com/keys , then:
#                LLM_PROVIDER=groq
#                LLM_API_KEY=gsk_...your_free_key...
#   gemini  -> Google AI Studio FREE tier (https://aistudio.google.com/apikey):
#                LLM_PROVIDER=gemini
#                LLM_API_KEY=...your_free_key...
#   ollama  -> Self-hosted, $0 FOREVER, but slow on a CPU VPS (~30-60s/answer). Key ignored.
#                LLM_PROVIDER=ollama      (run `ollama serve` + `ollama pull gemma2:2b`)

# --- Free public data sources (all optional; the keys below are free, no card, no "free-then-paid") ---
# U.S. Census API key (https://api.census.gov/data/key_signup.html). Population by state/metro and
# languages spoken work WITHOUT a key; this key additionally unlocks the Asian-Indian income /
# education / occupation profile (Selected Population Profile). Powers /insights + Dost's stats.
# CENSUS_API_KEY=
# Socrata app token (https://evergreen.data.socrata.com/signup) — open city/state datasets.
# Optional; only raises rate limits for the Socrata importer.
# SOCRATA_APP_TOKEN=
# DOL H-1B disclosure data (free, public domain) — top sponsors + typical wages by occupation into
# Dost's knowledge base. Blank = the quarterly H1BAgent stays dormant. Get the current file from
# https://www.dol.gov/agencies/eta/foreign-labor/performance (the "LCA Programs (H-1B...)" disclosure
# file). The annual file is large — prefer a single quarter, or convert .xlsx -> .csv if RAM is tight.
#   then:  docker compose -f docker-compose.prod.yml exec -T worker \
#            python -m indo_usa_mcp.cli h1b-import --source /path/or/url --year 2024
# DOL_H1B_DISCLOSURE_URL=
# DOL_H1B_FISCAL_YEAR=

# --- Google Analytics (optional) ---
# GA4 measurement ID (Admin -> Data Streams -> your web stream). Injected into every public page's
# <head> when set; blank = no tracking. It's public (visible in page source), not a secret.
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# --- Business registration captcha (optional) ---
# The registration form uses a free, built-in signed math captcha by default (no account needed).
# For a stronger widget, create a free Cloudflare Turnstile site (dash.cloudflare.com -> Turnstile)
# and set both keys; blank = keep the math captcha.
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
#   llm     -> Fully custom: set LLM_BASE_URL + LLM_MODEL + LLM_API_KEY yourself.
#
# NEVER commit a real key. Keep LLM_API_KEY in this .env / the host environment only.
# Override the preset's model/mode if you want (e.g. LLM_MODEL=llama-3.1-8b-instant for Groq).
CHAT_ENABLED=true
LLM_PROVIDER=search
LLM_API_KEY=
# LLM_BASE_URL / LLM_MODEL / LLM_USE_TOOLS are auto-set by the preset; set them only to override:
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=gemma2:2b
# LLM_USE_TOOLS=false
