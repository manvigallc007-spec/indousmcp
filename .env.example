# PostgreSQL connection (matches docker-compose.yml defaults)
# --- Local dev (optional) ---
# Leave DATABASE_URL blank to build it from the POSTGRES_* parts below (defaults already
# point at the dev container on localhost:5433). Set it only to override entirely.
# DATABASE_URL=postgresql://diaspora:diaspora@localhost:5433/diaspora

# --- Production stack (docker-compose.prod.yml) ---
# Strong DB password — ANY characters are now safe (the URL is encoded in code).
POSTGRES_PASSWORD=change-me-to-a-strong-password
# Your domain pointed at the VPS IP, for free HTTPS via the optional `tls` profile.
DOMAIN=yourdomain.com

# Pipeline behaviour
# Auto-apply new inserts whose confidence_score >= this threshold (skip approval queue).
AUTO_APPROVE_MIN_CONFIDENCE=0.6
# If false, every insert/update is routed to the human approval queue.
AUTO_APPROVE_LOW_RISK=true

# Scraper politeness
# Events: public iCalendar (.ics) feed URLs the event agent ingests (comma-separated).
# e.g. temple/community-org calendar export URLs. High-confidence events auto-approve;
# the rest appear under Admin → Events for approval.
EVENT_ICAL_FEEDS=

OVERPASS_URL=https://overpass-api.de/api/interpreter
SCRAPER_USER_AGENT=indo-usa-diaspora-mcp/0.1 (contact: manvigallc007@gmail.com)
SCRAPER_TIMEOUT_SECONDS=180

# Embeddings (semantic search)
# hashing = zero-dependency default; sentence_transformers = real semantics (pip install
# sentence-transformers, pulls torch); none = disable (search falls back to trigram).
# hashing = zero-dep default. fastembed = real semantic search (recommended; needs the
# `semantic` extra: pip install -e ".[semantic]", downloads a ~130MB model on first use).
EMBEDDING_PROVIDER=hashing
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Outreach & claiming
PLATFORM_NAME=Indian Eats Directory
CLAIM_BASE_URL=https://yourdomain.com/claim

# Public base URL of the claim/web app (used for Stripe redirect URLs)
PUBLIC_WEB_URL=http://YOUR_VPS_IP:8080

# Admin dashboard + owner portal. Blank ADMIN_PASSWORD disables /admin.
# SECRET_KEY signs session cookies + magic-link login tokens — set a long random value.
ADMIN_PASSWORD=
SECRET_KEY=change-me-to-a-long-random-string
REPORT_EMAIL=

# Payments (Stripe) — OPTIONAL. Blank STRIPE_SECRET_KEY = manual featuring (no checkout).
# Stripe charges only per sale (~2.9% + 30c), no monthly fee.
#   STRIPE_SECRET_KEY=sk_live_xxx   (from dashboard.stripe.com/apikeys)
#   STRIPE_WEBHOOK_SECRET=whsec_xxx (from the webhook you create -> /stripe/webhook)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_CENTS=3000
STRIPE_CURRENCY=usd
FEATURED_DAYS=30
OUTREACH_CONTACT_EMAIL=manvigallc007@gmail.com
OUTREACH_COOLDOWN_DAYS=21
# CAN-SPAM: a valid physical postal address is REQUIRED in every commercial email.
# Outreach auto-send stays OFF until this is set (until then it only drafts messages).
# A registered-agent / business mailing address or PO box is fine.
OUTREACH_POSTAL_ADDRESS=
# Slow ramp: max emails auto-sent per day across the whole platform (keep low to protect
# sender reputation and stay out of spam folders; raise gradually).
OUTREACH_DAILY_SEND_CAP=15

# Email delivery (OPTIONAL, zero-cost). Leave SMTP_HOST blank = outreach stays draft-only.
# NOTE: even with SMTP set, nothing sends until OUTREACH_POSTAL_ADDRESS is also set.
# For deliverability, send from your OWN domain with SPF/DKIM/DMARC configured — bulk cold
# email from a plain @gmail.com address will land in spam and risks account suspension.
# Free option: Gmail SMTP with an App Password (Google account → Security → App passwords).
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=youraddress@gmail.com
#   SMTP_PASSWORD=your-16-char-app-password
#   SMTP_FROM=youraddress@gmail.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Human chatbot front-end (/chat). Default = free, no-LLM semantic-search replies.
# For a REAL conversational, tool-calling bot, set LLM_PROVIDER=llm and point at an
# OpenAI-compatible endpoint:
#   - Self-hosted Ollama (free): run `ollama serve` + `ollama pull llama3.1`, then
#       LLM_PROVIDER=llm  LLM_BASE_URL=http://localhost:11434/v1  LLM_API_KEY=ollama  LLM_MODEL=llama3.1
#     (Needs RAM/CPU on the VPS; a small model like llama3.2:3b or qwen2.5:3b is lighter.)
#   - Hosted API (meters/bills — not zero-budget): set LLM_BASE_URL + a real LLM_API_KEY + LLM_MODEL.
CHAT_ENABLED=true
LLM_PROVIDER=search
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=llama3.1
