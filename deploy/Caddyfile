# Caddy auto-provisions a free Let's Encrypt TLS cert for $DOMAIN (+ www) and reverse-proxies:
#   /mcp*  -> MCP server (agents)        :8000
#   else   -> the web app                :8080  (incl. /stripe/webhook)
# Requires the domain (and www) pointed at the VPS IP.
{$DOMAIN} {
	handle /mcp* {
		reverse_proxy server:8000
	}
	handle {
		reverse_proxy web:8080
	}
}

# www -> apex (so www.namasteamerica.us redirects to namasteamerica.us)
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
